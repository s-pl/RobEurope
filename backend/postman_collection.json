{
  "info": {
    "_postman_id": "7c37e6f0-f87a-4d1e-b2b5-robeurope-api-v2",
    "name": "RobEurope API (Auth0 + Current Routes)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleccion actualizada para el backend real de RobEurope. Autenticacion de usuario mediante Auth0 (Bearer access token) y endpoint de cron protegido por CRON_SECRET."
  },
  "variable": [
    { "key": "root_url", "value": "http://localhost:85" },
    { "key": "base_url", "value": "http://localhost:85/api" },
    { "key": "access_token", "value": "" },
    { "key": "cron_secret", "value": "" },
    { "key": "user_query", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "team_id", "value": "" },
    { "key": "request_id", "value": "" },
    { "key": "competition_id", "value": "" },
    { "key": "registration_id", "value": "" },
    { "key": "post_id", "value": "" },
    { "key": "comment_id", "value": "" },
    { "key": "media_id", "value": "" },
    { "key": "center_id", "value": "" },
    { "key": "stream_id", "value": "" },
    { "key": "invite_token", "value": "" }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{root_url}}/health"
          }
        },
        {
          "name": "Features",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/features"
          }
        },
        {
          "name": "Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/stats"
          }
        },
        {
          "name": "Countries List",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/countries"
          }
        },
        {
          "name": "Posts List",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/posts"
          }
        },
        {
          "name": "Competitions List",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/competitions"
          }
        }
      ]
    },
    {
      "name": "Auth0 Profile",
      "item": [
        {
          "name": "Auth Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/auth/me"
          }
        },
        {
          "name": "Who Am I",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/whoami"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Users Search Public",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/users?q={{user_query}}"
          }
        },
        {
          "name": "Users Invite Search",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/users/search?q={{user_query}}"
          }
        },
        {
          "name": "Users Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/users/me"
          }
        },
        {
          "name": "Users Update Me",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Updated\",\n  \"last_name\": \"Profile\",\n  \"phone\": \"+34123456789\"\n}"
            },
            "url": "{{base_url}}/users/me"
          }
        },
        {
          "name": "Users Get By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/users/{{user_id}}"
          }
        }
      ]
    },
    {
      "name": "Teams",
      "item": [
        {
          "name": "Teams List",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/teams"
          }
        },
        {
          "name": "Teams Create",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Team Alpha\"\n}"
            },
            "url": "{{base_url}}/teams"
          }
        },
        {
          "name": "Teams Membership Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/teams/status"
          }
        },
        {
          "name": "Teams Mine",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/teams/mine"
          }
        },
        {
          "name": "Teams Request Join",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/teams/{{team_id}}/requests"
          }
        },
        {
          "name": "Teams List Join Requests",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/teams/{{team_id}}/requests"
          }
        },
        {
          "name": "Teams Approve Join Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/teams/requests/{{request_id}}/approve"
          }
        },
        {
          "name": "Teams Invite User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"target_user\"\n}"
            },
            "url": "{{base_url}}/teams/{{team_id}}/invite"
          }
        },
        {
          "name": "Teams Accept Invitation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{invite_token}}\"\n}"
            },
            "url": "{{base_url}}/teams/invitations/accept"
          }
        }
      ]
    },
    {
      "name": "Registrations",
      "item": [
        {
          "name": "Registrations List",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/registrations"
          }
        },
        {
          "name": "Registrations Create",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"competition_id\": {{competition_id}},\n  \"team_id\": {{team_id}}\n}"
            },
            "url": "{{base_url}}/registrations"
          }
        },
        {
          "name": "Registrations Approve (Super Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision_reason\": \"Meets requirements\"\n}"
            },
            "url": "{{base_url}}/registrations/{{registration_id}}/approve"
          }
        },
        {
          "name": "Registrations Center Approve",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision_reason\": \"Approved by center\"\n}"
            },
            "url": "{{base_url}}/registrations/{{registration_id}}/center-approve"
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Post Create (Center/Super Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "New announcement", "type": "text" },
                { "key": "content", "value": "Post created from Postman", "type": "text" }
              ]
            },
            "url": "{{base_url}}/posts"
          }
        },
        {
          "name": "Post Like Toggle",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/posts/{{post_id}}/like"
          }
        },
        {
          "name": "Post Add Comment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Great post\"\n}"
            },
            "url": "{{base_url}}/posts/{{post_id}}/comments"
          }
        }
      ]
    },
    {
      "name": "Media",
      "item": [
        {
          "name": "Media List",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/media"
          }
        },
        {
          "name": "Media Upload",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [] }
              ]
            },
            "url": "{{base_url}}/media"
          }
        },
        {
          "name": "Media Delete",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/media/{{media_id}}"
          }
        }
      ]
    },
    {
      "name": "Push",
      "item": [
        {
          "name": "Push VAPID Public Key",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/notifications/push/vapidPublicKey"
          }
        },
        {
          "name": "Push Subscribe",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"endpoint\": \"https://example.push/endpoint\",\n  \"keys\": {\n    \"p256dh\": \"sample\",\n    \"auth\": \"sample\"\n  }\n}"
            },
            "url": "{{base_url}}/notifications/push/subscribe"
          }
        },
        {
          "name": "Push Unsubscribe",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"endpoint\": \"https://example.push/endpoint\"\n}"
            },
            "url": "{{base_url}}/notifications/push/unsubscribe"
          }
        }
      ]
    },
    {
      "name": "Admin (Super Admin)",
      "item": [
        {
          "name": "Admin Stats Overview",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/admin/stats/overview"
          }
        },
        {
          "name": "Admin Users List",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/admin/users"
          }
        },
        {
          "name": "Admin Update User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"user\",\n  \"is_active\": true\n}"
            },
            "url": "{{base_url}}/admin/users/{{user_id}}"
          }
        },
        {
          "name": "Center Admin Requests",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{root_url}}/api/admin/center-requests"
          }
        }
      ]
    },
    {
      "name": "Cron",
      "item": [
        {
          "name": "Run Reminders Cron",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{cron_secret}}" }
            ],
            "url": "{{root_url}}/api/cron/reminders"
          }
        }
      ]
    }
  ]
}